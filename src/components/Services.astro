---
const { data } = Astro.props;
---
<section id="services" class="py-24 bg-primeleg-light">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h4 class="text-primeleg-accent font-bold uppercase tracking-widest text-sm mb-2">Nuestro Servicio Profesional</h4>
      <h2 class="text-4xl font-serif font-bold text-primeleg-primary">Áreas de <span class="text-primeleg-accent">Especialidad</span></h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {data.services.map((service) => (
        <div class="bg-white p-8 group hover:-translate-y-2 transition duration-300 shadow-sm hover:shadow-xl border-b-4 border-transparent hover:border-primeleg-accent">
          <div class="w-16 h-16 bg-primeleg-light flex items-center justify-center rounded-full mb-6 group-hover:bg-primeleg-accent transition">
            <svg class="w-8 h-8 text-primeleg-primary group-hover:text-white transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>
          </div>
          <h3 class="text-xl font-serif font-bold text-primeleg-primary mb-3">{service.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{service.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>