---
const { data } = Astro.props;
---
<section id="services" class="py-28 ">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h4 class="text-primeleg-primary font-bold text-[16px] mb-3 inline-block border-l-2 border-primeleg-accent pl-3">Our Professional Service</h4>
      <h2 class="text-[42px] font-serif font-bold text-primeleg-primary leading-[1.2]">Our Intellectual Property<br/>Copyright <span class="text-primeleg-accent">Law</span></h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {data.services.slice(0,3).map((service) => (
        <div class="bg-white group overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-300">
          <div class="relative w-full h-56 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1589829085413-56de8ae18c73?auto=format&fit=crop&w=600&q=80" alt="Service" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            
            <div class="absolute -bottom-8 left-1/2 transform -translate-x-1/2 w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-md">
              <div class="w-12 h-12 bg-primeleg-light rounded-full flex items-center justify-center text-primeleg-accent">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>
              </div>
            </div>
          </div>
          
          <div class="pt-12 pb-10 px-8 text-center">
            <h3 class="text-[22px] font-serif font-bold text-primeleg-primary mb-4 hover:text-primeleg-accent transition-colors"><a href="#">{service.title}</a></h3>
            <p class="text-gray-500 text-[15px] leading-relaxed m-0">{service.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>