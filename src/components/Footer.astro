---
const { data } = Astro.props;
---
<footer id="contact" class="bg-primeleg-dark text-gray-400 pt-20 pb-10">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <div>
        <a href="/" class="text-2xl font-serif font-bold text-white leading-tight block mb-6">
          PORTILLO KUS <br/><span class="text-sm text-primeleg-accent">& ASOCIADOS</span>
        </a>
        <p class="text-sm leading-relaxed mb-6">Defendemos firmemente la excelencia y las mejores prácticas legales en cada caso que representamos.</p>
        <div class="flex space-x-4">
          <a href={data.social.instagram} class="w-10 h-10 bg-gray-800 rounded flex items-center justify-center hover:bg-primeleg-accent hover:text-white transition">IG</a>
          <a href={data.social.telegram} class="w-10 h-10 bg-gray-800 rounded flex items-center justify-center hover:bg-primeleg-accent hover:text-white transition">TG</a>
        </div>
      </div>
      
      <div>
        <h4 class="text-white font-serif font-bold text-xl mb-6 border-b border-gray-800 pb-2">Enlaces Rápidos</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="/" class="hover:text-primeleg-accent transition">Inicio</a></li>
          <li><a href="#about" class="hover:text-primeleg-accent transition">Nosotros</a></li>
          <li><a href="#services" class="hover:text-primeleg-accent transition">Servicios</a></li>
          <li><a href="#testimonials" class="hover:text-primeleg-accent transition">Testimonios</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="text-white font-serif font-bold text-xl mb-6 border-b border-gray-800 pb-2">Servicios</h4>
        <ul class="space-y-3 text-sm">
          {data.services.map(s => (
            <li><a href="#services" class="hover:text-primeleg-accent transition">{s.title}</a></li>
          ))}
        </ul>
      </div>
      
      <div>
        <h4 class="text-white font-serif font-bold text-xl mb-6 border-b border-gray-800 pb-2">Contacto</h4>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start"><span class="text-primeleg-accent mr-3">📍</span> {data.address}</li>
          <li class="flex items-start"><span class="text-primeleg-accent mr-3">📞</span> {data.phone}</li>
          <li class="flex items-start"><span class="text-primeleg-accent mr-3">📧</span> {data.email}</li>
          <li class="flex items-start"><span class="text-primeleg-accent mr-3">🕒</span> {data.schedule}</li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center text-sm">
      <p>© {new Date().getFullYear()} {data.companyName}. Todos los derechos reservados.</p>
      <p class="mt-4 md:mt-0">Diseñado con Astro y Tailwind CSS</p>
    </div>
  </div>
</footer>