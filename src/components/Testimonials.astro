---
const { data } = Astro.props;
---
<section id="testimonials" class="py-24">
  <div class="container mx-auto px-4">
    <div class="flex flex-col lg:flex-row justify-between items-end mb-16">
      <div class="lg:w-1/2">
        <h4 class="text-primeleg-accent font-bold uppercase tracking-widest text-sm mb-2">Reseñas de Clientes</h4>
        <h2 class="text-4xl font-serif font-bold text-primeleg-primary">Muy Felices Por El <br/><span class="text-primeleg-accent">Feedback</span> De Nuestros Clientes</h2>
      </div>
      <div class="hidden lg:block">
        <a href={data.social.maps} target="_blank" class="text-primeleg-primary font-bold uppercase tracking-widest text-sm hover:text-primeleg-accent transition flex items-center group">
          Ver en Google Maps <span class="ml-2 transform group-hover:translate-x-1 transition">→</span>
        </a>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {data.testimonials.map((testi) => (
        <div class="bg-white p-8 shadow-md border border-gray-100 relative">
          <div class="flex text-primeleg-accent mb-4">
            {"★★★★★"}
          </div>
          <p class="text-gray-600 italic mb-8 relative z-10">"{testi.text}"</p>
          <div class="flex items-center">
            <div class="w-12 h-12 bg-primeleg-light rounded-full flex items-center justify-center text-primeleg-primary font-bold text-xl mr-4">
              {testi.name.charAt(0)}
            </div>
            <div>
              <h4 class="font-serif font-bold text-primeleg-primary">{testi.name}</h4>
              <span class="text-xs text-primeleg-accent uppercase tracking-widest">{testi.role}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>