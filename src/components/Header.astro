---
const { data } = Astro.props;
---
<header class="w-full z-50 bg-primeleg-dark sticky top-0 shadow-sm border-b border-gray-100">
  <div class="bg-primeleg-dark text-gray-400 text-[13px] py-2.5 hidden lg:block">
    <div class="container mx-auto px-4 flex justify-between items-center">
      <div><p class="m-0 italic">{data.tagline}</p></div>
      <div class="flex space-x-6 items-center">
        <span class="flex items-center"><span class="text-primeleg-accent mr-1.5">📍</span> {data.address}</span>
        <span class="flex items-center"><span class="text-primeleg-accent mr-1.5">✉️</span> {data.email}</span>
      </div>
    </div>
  </div>
  
  <div class="container mx-auto px-4 py-0 flex justify-between items-center h-20">
    <div class="flex items-center">
      <div class="w-10 h-12 bg-primeleg-primary text-white flex items-center justify-center font-serif font-bold text-xl rounded-b-lg mr-2">PK</div>
      <a href="/" class="text-xl md:text-2xl font-sans font-extrabold text-primeleg-primary uppercase tracking-wider leading-none">
        Portillo Kus <br/><span class="text-primeleg-accent text-sm">& Asociados</span>
      </a>
    </div>

    <nav class="hidden md:flex space-x-8 text-primeleg-primary font-bold text-[15px]">
      <a href="/" class="hover:text-primeleg-accent transition">Inicio</a>
      <a href="/#about" class="hover:text-primeleg-accent transition">Nosotros</a>
      <a href="/#services" class="hover:text-primeleg-accent transition">Especialidades</a>
      
      <a href="/consultas" class="hover:text-primeleg-accent transition flex items-center group">
        Catálogo de Consultas 
        <span class="ml-1 text-xs bg-primeleg-accent text-white px-2 py-0.5 rounded-full ml-2 group-hover:animate-pulse">NUEVO</span>
      </a>
      
      <a href="/#testimonials" class="hover:text-primeleg-accent transition">Reseñas</a>
    </nav>

    <div class="hidden md:flex items-center h-full">
      <a href={`https://wa.me/${data.phone1.replace(/\D/g, '')}`} target="_blank" class="h-full bg-primeleg-accent text-white px-8 font-bold text-[15px] flex items-center hover:bg-primeleg-primary transition-colors">
        WhatsApp <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </a>
    </div>
  </div>
</header>