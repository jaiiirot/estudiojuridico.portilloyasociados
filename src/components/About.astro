    <div class="relative">
      <div class="w-[80%] rounded-lg overflow-hidden relative z-10">
        <img src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=800&q=80" alt="Nosotros" class="w-full h-auto object-cover" />
      </div>
      <div class="absolute -bottom-10 -right-4 w-[50%] border-8 border-white rounded-lg overflow-hidden z-20 shadow-xl">
         <img src="https://images.unsplash.com/photo-1589829085413-56de8ae18c73?auto=format&fit=crop&w=400&q=80" alt="Detalle" class="w-full h-auto object-cover" />
      </div>
    </div>
    
    <div>
      <h4 class="text-primeleg-primary font-bold text-[16px] mb-3 border-l-2 border-primeleg-accent pl-3">Let's Get Printing</h4>
      <h2 class="text-[42px] font-serif font-bold text-primeleg-primary leading-[1.2] mb-6">
        Your Trusted <span class="text-primeleg-accent">Partner</span> In <br/>Complex Legal
