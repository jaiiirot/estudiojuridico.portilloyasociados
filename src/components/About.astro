      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
        <div>
          <h3 class="text-2xl font-serif font-bold text-primeleg-primary mb-3">Over 10 Year Of <span class="text-primeleg-accent">Experience</span></h3>
          <p class="text-gray-500 text-[15px]">Progressively visualize collaborative interfaces with revolutionary services Compellingly pontificate.</p>
        </div>
        <div>
           <h4 class="text-[17px] font-bold text-primeleg-primary leading-snug">Our Attorneys Deliver Tailored Legal</h4>
           <h5 class="text-[17px] font-bold text-primeleg-accent leading-snug">Solutions To Individuals.</h5>
        </div>
      </div>
      
      <a href="#about" class="inline-flex bg-primeleg-primary text-white px-8 py-4 font-bold text-[15px] hover:bg-primeleg-accent transition items-center">
        More About <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
