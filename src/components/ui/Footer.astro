---
const { data } = Astro.props;
---
<footer class="bg-web-background border-t border-web-secondary/30 text-gray-400 pt-24 pb-0">
  <div class="container mx-auto px-4 border-b border-web-secondary/50 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      
      <div>
        <div class="mb-6">
          <a href="/" class="inline-block outline-none">
            <img 
              src="/logoConNombreTransparente.png" 
              alt="Portillo Kus & Asociados Logo" 
              class="h-16 md:h-[72px] w-auto object-contain hover:opacity-80 transition-opacity duration-300" 
            />
          </a>
        </div>
        <p class="text-[15px] leading-relaxed mb-6">{data.hero.description}</p>
        
        <div class="flex flex-wrap gap-3">
          <a href={data.social.instagram} target="_blank" title="Instagram" class="w-10 h-10 bg-web-secondary/30 border border-web-secondary rounded-full flex items-center justify-center text-web-text hover:bg-web-primary hover:border-web-primary hover:text-web-background transition-all duration-300 transform hover:scale-110">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          
          <a href="https://www.tiktok.com/@abogadoenargentina" target="_blank" title="TikTok" class="w-10 h-10 bg-web-secondary/30 border border-web-secondary rounded-full flex items-center justify-center text-web-text hover:bg-web-primary hover:border-web-primary hover:text-web-background transition-all duration-300 transform hover:scale-110">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
          </a>
          
          <a href="https://t.me/abogadoenargentina" target="_blank" title="Telegram" class="w-10 h-10 bg-web-secondary/30 border border-web-secondary rounded-full flex items-center justify-center text-web-text hover:bg-web-primary hover:border-web-primary hover:text-web-background transition-all duration-300 transform hover:scale-110">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.888-.662 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </a>

          <a href="https://www.youtube.com/watch?v=I5zp4_cqZYk" target="_blank" title="YouTube" class="w-10 h-10 bg-web-secondary/30 border border-web-secondary rounded-full flex items-center justify-center text-web-text hover:bg-web-primary hover:border-web-primary hover:text-web-background transition-all duration-300 transform hover:scale-110">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.5 12 3.5 12 3.5s-7.505 0-9.377.55a3.016 3.016 0 0 0-2.122 2.136C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.55 9.376.55 9.376.55s7.505 0 9.377-.55a3.016 3.016 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>
      
      <div>
        <h4 class="text-web-primary font-serif font-bold text-[20px] mb-6">Enlaces Rápidos</h4>
        <ul class="space-y-3">
          <li><a href="/" class="hover:text-web-primary text-[15px] flex items-center transition-colors">» Inicio</a></li>
          <li><a href="/nosotros" class="hover:text-web-primary text-[15px] flex items-center transition-colors">» Nosotros</a></li>
          <li><a href="/#services" class="hover:text-web-primary text-[15px] flex items-center transition-colors">» Especialidades</a></li>
          <li><a href="/testimonios" class="hover:text-web-primary text-[15px] flex items-center transition-colors">» Reseñas de Clientes</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="text-web-primary font-serif font-bold text-[20px] mb-6">Nuestros Servicios</h4>
        <ul class="space-y-3">
          {data.services.map((s: { title: unknown; }) => (
            <li><a href="/#services" class="hover:text-web-primary text-[15px] flex items-center transition-colors">» {s.title}</a></li>
          ))}
        </ul>
      </div>
      
      <div>
        <h4 class="text-web-primary font-serif font-bold text-[20px] mb-6">Contacto y Pagos</h4>
        <ul class="space-y-3 mb-6 text-[14px]">
          <li><span class="text-web-primary">Sede:</span> {data.address}</li>
          <li><span class="text-web-primary">Tel:</span> {data.phone1}</li>
          <li><span class="text-web-primary">Horario:</span> {data.schedule}</li>
        </ul>
        <h5 class="text-web-primary font-serif font-bold text-[16px] mb-3">Métodos de Pago</h5>
        <p class="text-[14px] italic">{data.paymentMethods}</p>
      </div>

    </div>
  </div>
  
  <div class="container mx-auto px-4 py-6 text-center text-[14px]">
    <p>© Copyright {new Date().getFullYear()} Todos los derechos reservados por <span class="text-web-primary font-bold">{data.companyName}</span></p>
    <p class="mt-2 text-gray-500 text-[12px]">
      Desarrollado por <a href="https://norirstudio.vercel.app" target="_blank" rel="noopener noreferrer" class="text-web-primary hover:text-white transition-colors duration-300 font-medium">Norir Studio</a>
    </p>
  </div>
</footer>