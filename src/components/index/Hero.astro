---
const { data } = Astro.props;
const { hero } = data;
---
<section class="relative pt-24 pb-32 overflow-hidden flex items-center bg-web-background">
  <div class="container mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    
    <div class="z-10">
      <h4 class="text-web-text font-bold text-[15px] tracking-widest uppercase mb-6 border-l-2 border-web-primary pl-4">
        {hero.subtitle}
      </h4>
      <h1 class="text-[50px] lg:text-[65px] font-serif font-bold text-web-text leading-[1.1] mb-8">
        {hero.title} <br/><span class="text-web-primary">{hero.titleHighlight}</span>
      </h1>
      <p class="text-gray-300 text-[18px] mb-10 max-w-lg leading-relaxed">
        {hero.description}
      </p>
      <a href="/consultas/consultas" class="inline-flex bg-web-primary text-web-background px-10 py-4 font-bold text-[15px] uppercase tracking-wider hover:bg-web-secondary hover:text-web-text transition-colors duration-300 items-center">
        {hero.cta} 
        <svg class="w-5 h-5 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </a>
    </div>

    <div class="relative flex justify-end z-10 mt-12 lg:mt-0">
      <div class="absolute -top-8 -right-8 w-64 h-64 bg-[radial-gradient(#c69c6d_2px,transparent_2px)] [background-size:16px_16px] opacity-30 -z-10"></div>
      <div class="w-[90%] relative rounded-t-full overflow-hidden shadow-2xl border-b-8 border-web-primary">
        <img src="https://images.unsplash.com/photo-1589829085413-56de8ae18c73?auto=format&fit=crop&w=800&q=80" alt="Abogados" class="w-full h-[650px] object-cover hover:scale-105 transition-transform duration-700" />
      </div>
    </div>
    
  </div>
</section>