---
const { data } = Astro.props;

// Estrella formal en SVG. Repetiremos este string 5 veces.
const starSvg = `<svg class="w-4 h-4 text-primeleg-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>`;
---
<section id="testimonials" class="py-32 bg-white">
  <div class="container mx-auto px-4">
    <div class="flex flex-col lg:flex-row justify-between items-end mb-20">
      <div class="lg:w-2/3">
        <h4 class="text-primeleg-primary font-bold text-[15px] uppercase tracking-widest mb-4 border-l-2 border-primeleg-accent pl-4">
          Reseñas de Clientes
        </h4>
        <h2 class="text-[40px] lg:text-[50px] font-serif font-bold text-primeleg-primary leading-[1.2]">
          Muy Felices Por El <br/><span class="text-primeleg-accent">Feedback</span> De Nuestros Clientes
        </h2>
      </div>
      <div class="mt-8 lg:mt-0 pb-2">
        <a href="https://www.google.com/maps/search/?api=1&query=Portillo+Kus+Asociados" target="_blank" rel="noopener noreferrer" class="inline-flex items-center font-bold uppercase tracking-widest text-[14px] text-primeleg-primary hover:text-primeleg-accent transition-colors group">
          Ver en Google Maps 
          <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 xl:pr-6">
      {data.testimonials.map((testi) => (
        <div class="bg-white border border-gray-100 p-10 shadow-lg relative rounded-sm group hover:shadow-2xl transition-shadow duration-300 flex flex-col">
          
          <div class="flex space-x-1 mb-8" set:html={starSvg.repeat(5)}></div>
          
          <p class="text-gray-500 text-[16px] leading-relaxed mb-10 italic flex-grow">
            "{testi.text}"
          </p>
          
          <div>
            <h4 class="text-[20px] font-serif font-bold text-primeleg-primary">{testi.name}</h4>
            <span class="text-primeleg-accent text-[13px] font-bold uppercase tracking-widest">{testi.role}</span>
          </div>
          
          <div class="absolute top-1/2 -translate-y-1/2 -right-8 w-20 h-20 rounded-full border-4 border-white shadow-lg overflow-hidden group-hover:scale-110 transition-transform duration-300 hidden xl:block">
             <img src={`https://ui-avatars.com/api/?name=${encodeURIComponent(testi.name)}&background=122230&color=c69c6d&font-size=0.35&bold=true`} alt={testi.name} class="w-full h-full object-cover" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>