---
const { data } = Astro.props;

// SVG elegante de balanza/ley para las tarjetas
const iconSvg = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>`;
---
<section id="services" class="py-32 bg-primeleg-light">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <h4 class="text-primeleg-primary font-bold text-[15px] uppercase tracking-widest mb-4 inline-block border-l-2 border-primeleg-accent pl-4">
        Nuestro Servicio Profesional
      </h4>
      <h2 class="text-[40px] lg:text-[50px] font-serif font-bold text-primeleg-primary leading-[1.2]">
        Áreas de <span class="text-primeleg-accent">Especialidad</span>
      </h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {data.services.map((service) => (
        <div class="bg-white group overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 border-b-4 border-transparent hover:border-primeleg-accent flex flex-col">
          <div class="relative w-full h-52 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1589829085413-56de8ae18c73?auto=format&fit=crop&w=600&q=80" alt={service.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            
            <div class="absolute -bottom-8 left-1/2 transform -translate-x-1/2 w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-lg">
              <div class="w-12 h-12 bg-primeleg-light rounded-full flex items-center justify-center text-primeleg-accent group-hover:bg-primeleg-primary group-hover:text-white transition-colors duration-300" set:html={iconSvg} />
            </div>
          </div>
          
          <div class="pt-16 pb-10 px-8 text-center flex flex-col flex-grow">
            <h3 class="text-[20px] font-serif font-bold text-primeleg-primary mb-4 group-hover:text-primeleg-accent transition-colors">{service.title}</h3>
            <p class="text-gray-500 text-[15px] leading-relaxed m-0">{service.desc}</p>
          </div>
        </div>
      ))}
    </div>
    
    <div class="text-center mt-16">
       <a href="/consultas" class="inline-flex items-center font-bold uppercase tracking-widest text-[14px] text-primeleg-primary hover:text-primeleg-accent transition-colors group">
        Ver catálogo completo de servicios 
        <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </div>
  </div>
</section>