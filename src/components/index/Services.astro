---
// src/components/index/Services.astro

export interface ServiceItem {
  title: string;
  desc: string;
}

export interface Props {
  data: {
    services: ServiceItem[];
  };
}

const { data } = Astro.props;
---

<section id="services" class="py-32 bg-web-background border-t border-web-secondary/30">
  <div class="container max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="flex flex-col lg:flex-row gap-16">
      
      <div class="lg:w-1/3 lg:sticky lg:top-32 h-fit z-10">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-8 h-[1px] bg-web-primary"></span>
          <span class="text-web-primary font-bold tracking-widest uppercase text-[13px]">Especialidades</span>
        </div>
        
        <h2 class="text-4xl md:text-5xl font-serif font-bold text-web-text mb-8 leading-tight">
          Nuestras Áreas de Práctica
        </h2>
        
        <p class="text-gray-400 font-light text-[17px] mb-10 leading-relaxed">
          Intervención precisa en las ramas más críticas del derecho. Con una sólida trayectoria nacional e internacional, no tomamos casos, diseñamos soluciones.
        </p>
        
        <a href="/consultas/consultas" class="inline-flex items-center text-[13px] font-bold uppercase tracking-widest text-web-primary hover:text-web-text transition-colors group">
          Ver catálogo completo
          <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>

      <div class="lg:w-2/3 border-t border-web-secondary/30">
        {data.services.map((service, index) => (
          <a href="/consultas/consultas" class="group block border-b border-web-secondary/30 py-10 hover:bg-web-secondary/10 transition-all duration-300 px-4 md:px-8 -mx-4 md:-mx-8">
            <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-10">
              
              <span class="text-4xl lg:text-5xl font-serif font-light text-web-secondary group-hover:text-web-primary transition-colors duration-300">
                0{index + 1}
              </span>
              
              <div class="flex-grow">
                <h3 class="text-[22px] font-serif font-bold text-web-text mb-3 group-hover:text-web-primary transition-colors duration-300">
                  {service.title}
                </h3>
                <p class="text-gray-400 font-light leading-relaxed max-w-xl m-0 text-[16px]">
                  {service.desc}
                </p>
              </div>
              
              <div class="hidden md:flex flex-shrink-0 w-14 h-14 rounded-full border border-web-secondary/50 items-center justify-center group-hover:border-web-primary group-hover:bg-web-primary group-hover:text-web-background transition-all duration-300 text-web-primary">
                <svg class="w-6 h-6 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"></path></svg>
              </div>
              
            </div>
          </a>
        ))}
      </div>

    </div>

  </div>
</section>