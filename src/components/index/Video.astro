---
// src/components/index/Video.astro
---

<section class="py-24 bg-web-background relative overflow-hidden border-t border-web-secondary/20">
  
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-4xl h-[400px] bg-[radial-gradient(ellipse_at_center,_var(--tw-colors-web-primary)_0%,_transparent_70%)] opacity-10 pointer-events-none"></div>

  <div class="container max-w-5xl mx-auto px-4 relative z-10 text-center">
    
    <div class="flex items-center justify-center gap-4 mb-6">
      <span class="w-12 h-[1px] bg-web-primary"></span>
      <h4 class="text-web-text font-bold text-[13px] uppercase tracking-widest m-0">Conozca Nuestra Firma</h4>
      <span class="w-12 h-[1px] bg-web-primary"></span>
    </div>
    
    <h2 class="text-3xl md:text-5xl font-serif font-bold text-web-text mb-12">
      "El Derecho es <span class="text-web-primary italic font-light">Nuestra Pasión</span>"
    </h2>

    <div class="relative w-full aspect-video rounded-sm shadow-[0_20px_50px_-15px_rgba(0,0,0,0.8)] border border-web-secondary/50 overflow-hidden group bg-[#101c24]">
      
      <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-web-primary z-20 opacity-50 pointer-events-none transition-opacity duration-500 group-hover:opacity-100"></div>
      <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-web-primary z-20 opacity-50 pointer-events-none transition-opacity duration-500 group-hover:opacity-100"></div>
      
      <iframe 
        class="w-full h-full relative z-10"
        src="https://www.youtube.com/embed/I5zp4_cqZYk?rel=0&modestbranding=1" 
        title="Estudio Jurídico Portillo Kus & Asociados" 
        frameborder="0" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen>
      </iframe>
    </div>

  </div>
</section>