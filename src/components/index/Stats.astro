---
const { data } = Astro.props;
---
<section id="stats-section" class="relative bg-web-background border-y border-web-secondary/30 py-24 overflow-hidden">
  
  <div class="absolute inset-0 bg-[url('./oficina.png')] bg-cover bg-center bg-fixed opacity-[0.03]"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-web-background via-transparent to-web-background"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-0 divide-y md:divide-y-0 md:divide-x divide-web-secondary/40">
      
      <div class="flex flex-col items-center justify-center py-8 md:py-0 group">
        <div class="flex items-baseline mb-5 relative">
          <div class="absolute -inset-6 bg-web-primary/20 blur-3xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
          <h3 class="stat-number text-[70px] font-serif font-bold text-web-text leading-none transition-transform duration-500 group-hover:scale-105 drop-shadow-md" data-target={data.stats.resolved}>0</h3>
          <span class="text-[40px] font-serif font-bold text-web-primary ml-2">+</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="w-8 h-[1px] bg-web-primary/50 group-hover:bg-web-primary transition-colors duration-500"></span>
          <p class="text-gray-400 text-[13px] font-bold uppercase tracking-[0.2em] text-center leading-relaxed group-hover:text-gray-200 transition-colors duration-500">
            Expedientes<br/>Resueltos
          </p>
          <span class="w-8 h-[1px] bg-web-primary/50 group-hover:bg-web-primary transition-colors duration-500"></span>
        </div>
      </div>

      <div class="flex flex-col items-center justify-center py-8 md:py-0 group">
        <div class="flex items-baseline mb-5 relative">
          <div class="absolute -inset-6 bg-web-primary/20 blur-3xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
          <h3 class="stat-number-float text-[70px] font-serif font-bold text-web-text leading-none transition-transform duration-500 group-hover:scale-105 drop-shadow-md" data-target={data.stats.rating}>0.0</h3>
          <svg class="w-10 h-10 text-web-primary ml-3 -translate-y-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
        </div>
        <div class="flex items-center gap-3">
          <span class="w-8 h-[1px] bg-web-primary/50 group-hover:bg-web-primary transition-colors duration-500"></span>
          <p class="text-gray-400 text-[13px] font-bold uppercase tracking-[0.2em] text-center leading-relaxed group-hover:text-gray-200 transition-colors duration-500">
            Estrellas en<br/>Google Maps
          </p>
          <span class="w-8 h-[1px] bg-web-primary/50 group-hover:bg-web-primary transition-colors duration-500"></span>
        </div>
      </div>

      <div class="flex flex-col items-center justify-center py-8 md:py-0 group">
        <div class="flex items-baseline mb-5 relative">
          <div class="absolute -inset-6 bg-web-primary/20 blur-3xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
          <h3 class="stat-number text-[70px] font-serif font-bold text-web-text leading-none transition-transform duration-500 group-hover:scale-105 drop-shadow-md" data-target={data.stats.reviews}>0</h3>
          <span class="text-[40px] font-serif font-bold text-web-primary ml-2">+</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="w-8 h-[1px] bg-web-primary/50 group-hover:bg-web-primary transition-colors duration-500"></span>
          <p class="text-gray-400 text-[13px] font-bold uppercase tracking-[0.2em] text-center leading-relaxed group-hover:text-gray-200 transition-colors duration-500">
            Reseñas de<br/>Clientes
          </p>
          <span class="w-8 h-[1px] bg-web-primary/50 group-hover:bg-web-primary transition-colors duration-500"></span>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Función que hace subir los números suavemente
    const animateValue = (obj, start, end, duration, isFloat = false) => {
      let startTimestamp = null;
      const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        
        // Easing para que frene suavemente al final (easeOutExpo)
        const easeProgress = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
        
        const current = easeProgress * (end - start) + start;
        obj.innerHTML = isFloat ? current.toFixed(1) : Math.floor(current);
        
        if (progress < 1) {
          window.requestAnimationFrame(step);
        }
      };
      window.requestAnimationFrame(step);
    };

    // Observer que vigila cuándo la sección de stats aparece en la pantalla
    const observer = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          
          // Anima los números enteros (expedientes y reseñas)
          const intElements = entry.target.querySelectorAll('.stat-number');
          intElements.forEach(el => {
            const target = parseInt(el.getAttribute('data-target'));
            animateValue(el, 0, target, 2500); // 2.5 segundos
          });

          // Anima los números flotantes (estrellas)
          const floatElements = entry.target.querySelectorAll('.stat-number-float');
          floatElements.forEach(el => {
            const target = parseFloat(el.getAttribute('data-target'));
            animateValue(el, 0, target, 2500, true);
          });
          
          // Deja de vigilar una vez que ya se animaron
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 }); // Se activa cuando el 30% de la sección es visible

    const section = document.getElementById('stats-section');
    if (section) {
      observer.observe(section);
    }
  });
</script>