---
// Si prefieres pasarle los datos por props, puedes hacerlo, 
// pero aquí hardcodeamos los números reales del estudio sacados de tu .md
---
<section class="py-20 bg-primeleg-primary relative overflow-hidden">
  <div class="absolute inset-0 opacity-5 bg-[url('https://images.unsplash.com/photo-1589829085413-56de8ae18c73?auto=format&fit=crop&w=1920&q=80')] bg-cover bg-center bg-fixed"></div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 divide-y md:divide-y-0 md:divide-x divide-gray-700">
      
      <div class="text-center py-6 md:py-0 group">
        <div class="flex items-center justify-center text-5xl lg:text-6xl font-serif font-bold text-primeleg-accent mb-4 transition transform group-hover:scale-110">
          <span class="counter">900</span>
          <span>+</span>
        </div>
        <p class="text-white uppercase tracking-widest text-sm font-semibold">
          Expedientes <br/><span class="text-gray-400">Resueltos</span>
        </p>
      </div>

      <div class="text-center py-6 md:py-0 group">
        <div class="flex items-center justify-center text-5xl lg:text-6xl font-serif font-bold text-primeleg-accent mb-4 transition transform group-hover:scale-110">
          <span class="counter">5.0</span>
          <span class="text-3xl ml-2">⭐</span>
        </div>
        <p class="text-white uppercase tracking-widest text-sm font-semibold">
          Calificación <br/><span class="text-gray-400">En Google Maps</span>
        </p>
      </div>

      <div class="text-center py-6 md:py-0 group">
        <div class="flex items-center justify-center text-5xl lg:text-6xl font-serif font-bold text-primeleg-accent mb-4 transition transform group-hover:scale-110">
          <span class="counter">339</span>
          <span>+</span>
        </div>
        <p class="text-white uppercase tracking-widest text-sm font-semibold">
          Reseñas de <br/><span class="text-gray-400">Clientes Satisfechos</span>
        </p>
      </div>

    </div>
  </div>
</section>