---
const { data } = Astro.props;
---
<section class="bg-primeleg-primary py-24 relative">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-gray-700/50">
      
      <div class="flex flex-col items-center justify-center py-6">
        <div class="flex items-baseline mb-2">
          <h3 class="text-[60px] font-bold text-white leading-none">{data.stats.resolved}</h3>
          <span class="text-[40px] font-bold text-primeleg-accent ml-1">+</span>
        </div>
        <p class="text-gray-300 text-[16px] leading-tight font-medium text-center uppercase tracking-widest">Expedientes<br/>Resueltos</p>
      </div>

      <div class="flex flex-col items-center justify-center py-6">
        <div class="flex items-baseline mb-2">
          <h3 class="text-[60px] font-bold text-white leading-none">{data.stats.rating}</h3>
          <span class="text-[40px] font-bold text-primeleg-accent ml-2">⭐</span>
        </div>
        <p class="text-gray-300 text-[16px] leading-tight font-medium text-center uppercase tracking-widest">Estrellas en<br/>Google Maps</p>
      </div>

      <div class="flex flex-col items-center justify-center py-6">
        <div class="flex items-baseline mb-2">
          <h3 class="text-[60px] font-bold text-white leading-none">{data.stats.reviews}</h3>
          <span class="text-[40px] font-bold text-primeleg-accent ml-1">+</span>
        </div>
        <p class="text-gray-300 text-[16px] leading-tight font-medium text-center uppercase tracking-widest">Reseñas de<br/>Clientes</p>
      </div>

    </div>
  </div>
</section>