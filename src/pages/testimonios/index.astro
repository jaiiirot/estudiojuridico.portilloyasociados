---
import Layout from '../../layouts/Layout.astro';
import { testimoniosData } from '../../data/testimonios';

const starSvg = `<svg class="w-4 h-4 text-web-primary" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>`;
---

<Layout 
  title="Testimonios y Reseñas | Portillo Kus & Asociados"
  description="Vea lo que dicen nuestros clientes sobre nuestra gestión en Ciudadanías, Derecho Migratorio y Defensa Penal."
>
  <div class="w-full bg-web-background pb-32 border-t border-web-secondary/20">
    
    <div class="bg-web-secondary/10 pt-32 pb-20 px-4 text-center">
      <div class="flex flex-col items-center mb-8">
        <div class="flex gap-1 mb-4">
          <Fragment set:html={starSvg.repeat(5)} />
        </div>
        <h1 class="text-4xl md:text-6xl font-serif font-bold text-web-text mb-4">
          Opiniones de <span class="text-web-primary italic font-light">Nuestros Clientes</span>
        </h1>
        <p class="text-gray-400 max-w-2xl mx-auto text-lg leading-relaxed">
          Nuestra mayor garantía es el éxito de quienes confiaron en nosotros. 
          Contamos con una calificación de <strong>5.0 estrellas</strong> basada en más de 300 reseñas reales.
        </p>
      </div>

      <div class="max-w-md mx-auto relative group">
        <input 
          type="text" 
          id="testimonialSearch"
          placeholder="Filtrar por trámite (ej: Ciudadanía, Visa...)"
          class="w-full bg-web-background border border-web-secondary/50 rounded-sm py-4 px-6 text-web-text placeholder:text-gray-600 focus:outline-none focus:border-web-primary transition-all shadow-xl"
        />
      </div>
    </div>

    <div class="container max-w-7xl mx-auto px-4 mt-12">
      <div id="testimoniosGrid" class="columns-1 md:columns-2 lg:columns-3 gap-8 space-y-8">
        {testimoniosData.map((t) => (
          <div class="testimonial-card break-inside-avoid bg-web-secondary/10 border border-web-secondary/30 p-8 rounded-sm hover:border-web-primary/50 transition-all duration-300 shadow-lg" 
               data-text={t.text.toLowerCase()} 
               data-name={t.name.toLowerCase()}>
            
            <div class="flex justify-between items-start mb-6">
              <div class="flex gap-1">
                <Fragment set:html={starSvg.repeat(t.rating)} />
              </div>
              <span class="text-[12px] text-gray-500 uppercase tracking-tighter">{t.date}</span>
            </div>

            <p class="text-[15px] text-gray-300 leading-relaxed italic mb-8">
              "{t.text}"
            </p>

            <div class="flex items-center gap-4 border-t border-web-secondary/20 pt-6">
              <div class="w-10 h-10 rounded-full bg-web-primary/20 flex items-center justify-center text-web-primary font-bold text-sm">
                {t.name.charAt(0)}
              </div>
              <div>
                <h4 class="text-web-text font-serif font-bold text-[16px] leading-none mb-1">{t.name}</h4>
                <p class="text-[12px] text-web-primary uppercase tracking-widest">{t.info}</p>
              </div>
            </div>

            {t.reply && (
              <div class="mt-6 p-4 bg-web-background/50 border-l-2 border-web-primary">
                <p class="text-[13px] text-gray-400 m-0">
                  <span class="text-web-primary font-bold block mb-1 uppercase text-[10px] tracking-widest">Respuesta del Estudio:</span>
                  {t.reply}
                </p>
              </div>
            )}
          </div>
        ))}
      </div>

      <div id="noTestimonios" class="hidden text-center py-20">
        <p class="text-gray-500 text-lg font-serif">No se encontraron experiencias con esos términos.</p>
      </div>
    </div>

    <div class="text-center mt-20">
      <a href="https://www.google.com/maps/place/Portillo+Kus+%26+Asociados.+Estudio+Jur%C3%ADdico/@-34.5998608,-58.4141894,14z/data=!4m12!1m2!2m1!1sabogados!3m8!1s0x95bccba3e8bdb1fb:0x680786357004fb40!8m2!3d-34.6071757!4d-58.3752813!9m1!1b1!15sCghhYm9nYWRvc1oKIghhYm9nYWRvc5IBDmxlZ2FsX3NlcnZpY2VzmgFEQ2k5RFFVbFJRVU52WkVOb2RIbGpSamx2VDJ4R1dVNXNTbXRsV0dSMVRVUldRbFZzU2toUFZrNXlXRE5PUW1SdFl4QULgAQD6AQQIRhBC!16s%2Fg%2F11v014vn49?entry=ttu&g_ep=EgoyMDI2MDQwNi4wIKXMDSoASAFQAw%3D%3D" target="_blank" class="inline-flex items-center gap-2 text-web-primary hover:text-web-text font-bold uppercase text-[13px] tracking-widest transition-colors">
        Ver todas las reseñas originales en Google Maps
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
      </a>
    </div>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById('testimonialSearch') as HTMLInputElement;
  const cards = document.querySelectorAll('.testimonial-card');
  const noResults = document.getElementById('noTestimonios');

  searchInput?.addEventListener('input', (e) => {
    const term = (e.target as HTMLInputElement).value.toLowerCase();
    let count = 0;

    cards.forEach((card) => {
      const text = card.getAttribute('data-text') || '';
      const name = card.getAttribute('data-name') || '';
      
      if (text.includes(term) || name.includes(term)) {
        (card as HTMLElement).style.display = 'block';
        count++;
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });

    if (count === 0) noResults?.classList.remove('hidden');
    else noResults?.classList.add('hidden');
  });
</script>