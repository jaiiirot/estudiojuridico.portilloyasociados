---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/index/Hero.astro';
import About from '../components/index/About.astro';
import TikTokGallery from '../components/index/TikTokGallery.astro'; // <-- IMPORTAMOS EL VIDEO
import Services from '../components/index/Services.astro';
import Stats from '../components/index/Stats.astro';
import Testimonials from '../components/index/Testimonials.astro';
import { siteData } from '../data/site';
---

<Layout title={`${siteData.companyName} - Inicio`}>
  <Hero data={siteData} />
  
  <About data={siteData} />
  
  <TikTokGallery />
  
  <Services data={siteData} />
  <Stats data={siteData} />
  <Testimonials data={siteData} />
</Layout>