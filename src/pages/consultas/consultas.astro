---
import Layout from '../layouts/Layout.astro';
import { consultasData } from '../data/consultas';
---

<Layout 
  title="Catálogo de Consultas Rápidas | Portillo Kus & Asociados"
  description="Seleccione el área legal de su interés para ser redirigido a nuestro canal prioritario de atención por WhatsApp."
>
  <div class="w-full bg-primeleg-light pb-28">
    
    <div class="bg-primeleg-primary pt-32 pb-24 px-4 text-center">
      <h4 class="text-primeleg-accent font-bold text-[15px] uppercase tracking-widest mb-4">Atención Inmediata</h4>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-white mb-6 leading-tight">
        Catálogo de <span class="text-primeleg-accent">Consultas</span>
      </h1>
      <p class="text-gray-300 max-w-2xl mx-auto text-[17px] leading-relaxed">
        Seleccione el área legal de su interés para contactarse de forma directa y prioritaria con nuestro equipo de especialistas.
      </p>
    </div>

    <div class="container mx-auto px-4 -mt-10 relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
        {consultasData.map((consulta) => (
          <div class="bg-white p-8 rounded-sm shadow-lg hover:shadow-2xl border-t-4 border-transparent hover:border-primeleg-accent transition-all duration-300 group flex flex-col justify-between h-full">
            <div>
              <div class="w-14 h-14 bg-primeleg-light rounded-full flex items-center justify-center mb-6 group-hover:bg-primeleg-primary transition-colors duration-300">
                <div class="text-primeleg-accent group-hover:text-white transition-colors duration-300" set:html={consulta.icon} />
              </div>
              <h3 class="text-[20px] font-serif font-bold text-primeleg-primary mb-4 leading-snug group-hover:text-primeleg-accent transition-colors">{consulta.title}</h3>
              <p class="text-[15px] text-gray-500 mb-8 leading-relaxed">{consulta.desc}</p>
            </div>
            
            <a href={consulta.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-[14px] font-bold uppercase tracking-wider text-primeleg-primary group-hover:text-primeleg-accent transition-colors mt-auto">
              Iniciar Consulta 
              <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>