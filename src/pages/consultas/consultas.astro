---
import Layout from '../../layouts/Layout.astro';
import { consultasData } from '../../data/consultas';
---

<Layout 
  title="Catálogo de Consultas Rápidas | Portillo Kus & Asociados"
  description="Seleccione el área legal de su interés para ser redirigido a nuestro canal prioritario de atención por WhatsApp."
>
  <div class="w-full bg-web-background pb-32 border-t border-web-secondary/20 relative overflow-hidden">
    
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-5xl h-96 bg-[radial-gradient(ellipse_at_top,_var(--tw-colors-web-secondary)_0%,_transparent_70%)] opacity-20 pointer-events-none"></div>

    <div class="relative z-10 pt-32 pb-12 px-4 text-center">
      <div class="flex items-center justify-center gap-4 mb-6">
        <span class="w-12 h-[1px] bg-web-primary/50"></span>
        <h4 class="text-web-primary font-bold text-[13px] uppercase tracking-widest m-0">Atención Inmediata</h4>
        <span class="w-12 h-[1px] bg-web-primary/50"></span>
      </div>
      
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-serif font-bold text-web-text mb-8 leading-tight drop-shadow-lg">
        Catálogo de <span class="text-web-primary italic font-light">Consultas</span>
      </h1>
      
      <p class="text-gray-400 max-w-2xl mx-auto text-[17px] font-light leading-relaxed mb-12">
        Seleccione el área legal de su interés para recibir asistencia directa, confidencial y prioritaria por parte de nuestros especialistas.
      </p>

      <div class="max-w-md mx-auto relative group">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-web-primary/50 group-focus-within:text-web-primary transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
        <input 
          type="text" 
          id="legalSearch"
          placeholder="Buscar especialidad (ej: Ciudadanía, Divorcio...)"
          class="w-full bg-[#101c24] border border-web-secondary/30 rounded-sm py-4 pl-12 pr-4 text-web-text placeholder:text-gray-500 focus:outline-none focus:border-web-primary/50 focus:ring-1 focus:ring-web-primary/20 transition-all shadow-inner"
        />
      </div>
    </div>

    <div class="container max-w-7xl mx-auto px-4 relative z-10 mt-8">
      <div id="consultasGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {consultasData.map((consulta) => (
          <a 
            href={consulta.url} 
            target="_blank" 
            rel="noopener noreferrer" 
            data-title={consulta.title.toLowerCase()}
            data-desc={consulta.desc.toLowerCase()}
            class="consulta-card group relative flex flex-col p-10 bg-[#101c24] border border-web-secondary/30 transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.8)] hover:border-web-primary/50 overflow-hidden"
          >
            <div class="absolute top-0 right-0 w-24 h-24 overflow-hidden pointer-events-none">
              <div class="absolute -top-12 -right-12 w-24 h-24 bg-web-primary/5 rotate-45 transition-colors duration-500 group-hover:bg-web-primary/20"></div>
            </div>

            <div class="w-14 h-14 mb-8 flex items-center justify-center rounded-sm bg-web-background border border-web-secondary/50 text-web-secondary transition-all duration-500 group-hover:border-web-primary group-hover:text-web-primary group-hover:scale-110">
              <Fragment set:html={consulta.icon} />
            </div>
            
            <h3 class="text-[22px] font-serif font-bold text-web-text mb-4 leading-snug transition-colors duration-300 group-hover:text-web-primary pr-4">
              {consulta.title}
            </h3>
            
            <p class="text-gray-400 text-[15px] font-light leading-relaxed mb-10 flex-grow">
              {consulta.desc}
            </p>
            
            <div class="flex items-center justify-between mt-auto border-t border-web-secondary/30 pt-6 transition-colors duration-500 group-hover:border-web-primary/30">
              <span class="text-[12px] font-bold uppercase tracking-widest text-web-primary">Iniciar Consulta</span>
              
              <div class="w-10 h-10 rounded-full border border-web-secondary/50 flex items-center justify-center transition-all duration-500 group-hover:bg-web-primary group-hover:border-web-primary group-hover:text-web-background text-web-primary">
                <svg class="w-5 h-5 transform transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </div>
            </div>

            <div class="absolute bottom-0 left-0 w-0 h-[3px] bg-web-primary transition-all duration-500 ease-out group-hover:w-full"></div>
          </a>
        ))}
      </div>
      
      <div id="noResults" class="hidden text-center py-20">
        <p class="text-gray-500 text-lg font-serif italic">No se encontraron especialidades que coincidan con su búsqueda.</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Lógica del buscador en el cliente
  const searchInput = document.getElementById('legalSearch') as HTMLInputElement;
  const cards = document.querySelectorAll('.consulta-card');
  const noResults = document.getElementById('noResults');

  searchInput?.addEventListener('input', (e) => {
    const term = (e.target as HTMLInputElement).value.toLowerCase();
    let hasResults = false;

    cards.forEach((card) => {
      const title = card.getAttribute('data-title') || '';
      const desc = card.getAttribute('data-desc') || '';
      
      if (title.includes(term) || desc.includes(term)) {
        (card as HTMLElement).style.display = 'flex';
        hasResults = true;
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });

    // Mostrar/Ocultar mensaje de "no resultados"
    if (hasResults) {
      noResults?.classList.add('hidden');
    } else {
      noResults?.classList.remove('hidden');
    }
  });
</script>