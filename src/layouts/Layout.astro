---
// src/layouts/Layout.astro
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/ui/Header.astro';
import Footer from '../components/ui/Footer.astro';
import Chatbot from '../components/ui/Chatbot.astro';
import { siteData } from '../data/site';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
  title = `${siteData.companyName} - Estudio Jurídico Integral`,
  description = siteData.hero.description,
  image = "/miniatura.png" // Asegúrate de que este archivo exista en public/
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://www.estudioportilloyasociados.vercel.app');

// Schema.org para posicionamiento SEO Local en Google (LegalService)
const schema = {
  "@context": "https://schema.org",
  "@type": "LegalService",
  "name": siteData.companyName,
  "image": new URL(image, canonicalURL).toString(),
  "@id": canonicalURL.toString(),
  "url": canonicalURL.toString(),
  "telephone": siteData.phone1,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Av. Pte. R. Sáenz Peña 616, Piso 4, Oficina 403",
    "addressLocality": "Ciudad Autónoma de Buenos Aires",
    "addressRegion": "CABA",
    "postalCode": "C1035",
    "addressCountry": "AR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -34.6037, // Coordenadas aproximadas del centro porteño
    "longitude": -58.3816
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "09:00",
    "closes": "18:00"
  },
  "priceRange": "$$$",
  "knowsAbout": [
    "Ciudadanía Argentina",
    "Ciudadanía Italiana",
    "Ciudadanía Española",
    "Derecho Migratorio",
    "Derecho Penal",
    "Derecho Laboral",
    "Derecho de Familia",
    "Divorcios",
    "Visas"
  ]
};
---
<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="author" content={siteData.companyName}>
  <link rel="canonical" href={canonicalURL} />
  
  <ClientRouter />

  <link rel="icon" type="image/png" href="/logo.png" />
  <meta name="generator" content={Astro.generator} />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL.toString()} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, canonicalURL).toString()} />
  <meta property="og:site_name" content={siteData.companyName} />

  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL.toString()} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, canonicalURL).toString()} />
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
</head>
<body class="font-sans text-web-text bg-web-background antialiased flex flex-col min-h-screen">
  <Header data={siteData} />
  <main class="flex-grow w-full">
    <slot />
  </main>
  <Chatbot />
  <Footer data={siteData} />
</body>
</html>